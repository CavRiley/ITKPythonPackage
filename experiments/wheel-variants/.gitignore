# Pixi env state
.pixi/

# Pilot build artifacts
pilot/build/
pilot/dist/
pilot/_skbuild/
pilot/*.egg-info/

# Wheels dropped into mock fixtures (real ITK wheels — too large + binary)
mock/fixtures/*.whl
mock/fixtures/*-tbbon.whl
mock/fixtures/*-null.whl

# Local scratch
.devlocal/

# The repo-root .gitignore has a broad `src` rule that would otherwise
# sweep up the pilot's source directory. Re-include it explicitly.
!pilot/src/
!pilot/src/**
